  <name>Crypto Dashboard</name>
  <summary>Real-time cryptocurrency dashboard with candlestick charts</summary>
  <description>
    <p>
      Crypto Dashboard is a Qt (PyQt6) desktop app that streams live prices from
      Binance and draws real-time candlestick charts with a volume overlay,
      multiple timeframes, a live ticker table and a saved coin watchlist.
    </p>
  </description>
  <launchable type="desktop-id">io.github.michwill.crypto_dashboard.desktop</launchable>
  <provides>
    <binary>crypto-dashboard</binary>
  </provides>
  <categories>
    <category>Office</category>
    <category>Finance</category>
  </categories>
  <screenshots>
